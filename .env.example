# Base URL of the RealEstateBroker backend API (include the /api/v1 prefix).
#
# Use a relative base URL (/api/v1) so browser requests stay same-origin:
# - Local dev: Vite proxies /api to the backend (VITE_DEV_PROXY_TARGET below).
# - Vercel: vercel.json rewrites /api to the production API.
VITE_API_BASE_URL=/api/v1

# Dev-only — Vite proxy target when running `npm run dev`.
VITE_DEV_PROXY_TARGET=https://api2.senam.tech

# Production API (for reference; used by vercel.json rewrite, not as VITE_API_BASE_URL):
# https://api2.senam.tech/api/v1

# API major version sent as the X-API-Version header.
VITE_API_MAJOR=v1

# Optional dev-only proxy overrides (see vite.config.ts).
# VITE_DEV_API_PORT=3000
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:3000
