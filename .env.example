# Base URL of the RealEstateBroker backend API (include the /api/v1 prefix).
#
# Do NOT set an absolute URL here for browser builds — it causes CORS on Vercel.
# Use /api/v1; Vite (dev) and vercel.json (prod) proxy to the real API.
VITE_API_BASE_URL=/api/v1

# Optional: remote API origin for the dev proxy only (ignored in the browser bundle).
# VITE_API_BASE_URL=https://api2.senam.tech/api/v1

# API major version sent as the X-API-Version header.
VITE_API_MAJOR=v1

# Optional dev-only proxy overrides (see vite.config.ts).
# VITE_DEV_API_PORT=3000
# VITE_DEV_PROXY_TARGET=https://api2.senam.tech
