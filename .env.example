# Base URL of the RealEstateBroker backend API (include the /api/v1 prefix).
#
# Production (matches mobile API_BASE_URL):
VITE_API_BASE_URL=https://api2.senam.tech/api/v1
#
# Local backend via Vite proxy (uncomment and comment the line above):
# VITE_API_BASE_URL=/api/v1

# API major version sent as the X-API-Version header.
VITE_API_MAJOR=v1

# Optional dev-only proxy overrides (see vite.config.ts).
# VITE_DEV_API_PORT=3000
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:3000
