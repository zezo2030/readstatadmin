# Base URL of the RealEstateBroker backend API (include the /api/v1 prefix).
# In dev you can leave this as the relative path below and rely on the Vite
# proxy (see vite.config.ts) which forwards /api -> http://localhost:3000.
VITE_API_BASE_URL=/api/v1

# API major version sent as the X-API-Version header.
VITE_API_MAJOR=v1
